# When set, student audio is uploaded to S3 instead of local disk. URLs are stored in DB.
# AWS_VOICE_BUCKET_NAME=eel-voice-recordings
# AWS_BUCKET_NAME=eel-voice-recordings
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=ap-southeast-2

# S3 profile avatars (settings page) — uses AWS_BUCKET_NAME if AWS_AVATAR_BUCKET_NAME not set
# AWS_AVATAR_BUCKET_NAME=eel-avatar

